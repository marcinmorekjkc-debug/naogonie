# Skopiuj ten plik do .env i uzupełnij prawdziwymi wartościami.

# ---------- Baza danych PostgreSQL ----------
# Adres połączenia do bazy — dostaniesz go od dostawcy hostingu bazy (patrz README, sekcja o Render/Supabase/Neon).
DATABASE_URL=postgres://uzytkownik:haslo@host:5432/nazwa_bazy
# Zostaw na true (domyślnie) dla większości hostingów w chmurze (wymagają SSL). Ustaw na false dla lokalnej bazy bez SSL.
DATABASE_SSL=true

# Sekret do podpisywania sesji logowania administratora — wygeneruj losowy, długi ciąg znaków.
SESSION_SECRET=zmien-to-na-losowy-dlugi-ciag-znakow

# Dashboard Stripe -> Developers -> API keys -> Secret key (zaczyna się od sk_test_ lub sk_live_)
STRIPE_SECRET_KEY=sk_test_TWOJKLUCZ

# Dashboard Stripe -> Product catalog -> stwórz JEDEN produkt "NaOgonie.pl — abonament"
# i TRZY ceny cykliczne (Recurring) przypięte do niego:
#   - 24,99 PLN, co 1 miesiąc
#   - 139,99 PLN, co 6 miesięcy (interval: month, interval count: 6)
#   - 249,99 PLN, co 1 rok
# Skopiuj ID każdej z cen (zaczynają się od price_) poniżej.
STRIPE_PRICE_MONTHLY=price_TWOJEID_MIESIECZNY
STRIPE_PRICE_SIXMONTH=price_TWOJEID_POLROCZNY
STRIPE_PRICE_YEARLY=price_TWOJEID_ROCZNY

# Dashboard Stripe -> Developers -> Webhooks -> Add endpoint -> https://twoj-backend.com/webhook
# Po utworzeniu endpointu Stripe pokaże "Signing secret" (zaczyna się od whsec_)
STRIPE_WEBHOOK_SECRET=whsec_TWOJSEKRET

# Adres, pod którym działa Twoja aplikacja webowa (do przekierowania po płatności)
FRONTEND_URL=https://twoja-domena.pl

PORT=4242

# Wysyłka maila z formularza kontaktowego (np. Gmail SMTP, SendGrid, Mailgun, Resend przez SMTP)
CONTACT_EMAIL=kontakt@naogonie.pl
SMTP_HOST=smtp.twojdostawca.pl
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=twoj_login_smtp
SMTP_PASS=twoje_haslo_smtp
